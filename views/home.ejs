<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', {
    pageTitle: pageTitle,
    pageDescription: pageDescription,
    canonicalUrl,
    canonicalPath,
    ogImage,
    structuredData
  }) %>
</head>
<body class="page">
  <%- include('partials/nav') %>

  <main class="page-main">
    <section class="hero-band">
      <div class="hero-band__inner shell">
        <div class="hero-copy reveal-on-scroll">
          <p class="eyebrow"><%= site.hero.eyebrow %></p>
          <h1><%= site.hero.headline %></h1>
          <p class="lede"><%= site.hero.body %></p>
          <p class="hero-support"><%= site.home.keywordCopy %></p>

          <div class="hero-actions">
            <a class="button button-primary" href="/subscribe">Start weekly delivery</a>
            <a class="button button-secondary" href="/shop">Buy a single box</a>
          </div>

          <ul class="promise-list">
            <% site.promiseStrip.forEach((item) => { %>
              <li><%= item %></li>
            <% }) %>
          </ul>
        </div>

        <div class="hero-visual reveal-on-scroll">
          <div class="hero-visual__frame">
            <img
              src="/images/pattambi-microgreens-fresh.jpg"
              alt="Farm fresh microgreens harvested for weekly delivery in Pattambi Kerala"
              width="1400"
              height="933"
            >
          </div>
          <div class="hero-note">
            <span>Hyperlocal delivery belt</span>
            <strong>Harvested locally and delivered fast across the Pattambi-Malappuram side of Kerala.</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="section shell">
      <div class="section-heading">
        <h2><%= site.serviceAreasHeading %></h2>
        <p><%= site.home.serviceIntro %></p>
      </div>

      <div class="content-grid content-grid--four">
        <% site.serviceAreas.forEach((area) => { %>
          <article class="content-block reveal-on-scroll">
            <h3><%= area.title %></h3>
            <p><%= area.body %></p>
            <a class="text-link" href="<%= area.href %>">See delivery details</a>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="section section--tint">
      <div class="shell">
        <div class="section-heading">
          <h2>Why Sprig &amp; Soil?</h2>
          <p><%= site.home.whyIntro %></p>
        </div>

        <div class="content-grid content-grid--three">
          <% site.principles.forEach((principle) => { %>
            <article class="content-block reveal-on-scroll">
              <h3><%= principle.title %></h3>
              <p><%= principle.body %></p>
            </article>
          <% }) %>
        </div>
      </div>
    </section>

    <section class="section shell">
      <div class="section-heading">
        <h2>How It Works</h2>
        <p><%= site.home.howItWorksIntro %></p>
      </div>

      <div class="content-grid content-grid--four">
        <% site.steps.forEach((step, index) => { %>
          <article class="process-step reveal-on-scroll">
            <span class="process-step__number">0<%= index + 1 %></span>
            <h3><%= step.title %></h3>
            <p><%= step.body %></p>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="section section--tint">
      <div class="shell feature-split">
        <div class="feature-copy">
          <div class="section-heading section-heading--compact">
            <h2>This Week&apos;s Box</h2>
            <p><%= site.home.boxIntro %></p>
          </div>

          <div class="content-grid content-grid--two">
            <% products.forEach((product) => { %>
              <article class="product-preview reveal-on-scroll">
                <div class="product-preview__meta">
                  <span class="pill pill--soft"><%= product.label %></span>
                  <strong>₹<%= (product.priceInPaise / 100).toFixed(0) %></strong>
                </div>
                <h3><%= product.name %></h3>
                <p><%= product.flavor %></p>
                <span class="product-preview__usage"><%= product.usage %></span>
              </article>
            <% }) %>
          </div>
        </div>

        <div class="feature-media reveal-on-scroll">
          <img
            src="/images/kerala-microgreens-growing-trays.jpg"
            alt="Microgreens growing in soil for delivery across Pattambi and Valanchery Kerala"
            loading="lazy"
            width="1200"
            height="1800"
          >
        </div>
      </div>
    </section>

    <section class="section shell">
      <div class="section-heading">
        <h2>What Our Subscribers Say</h2>
        <p>Customers reorder because the greens fit breakfast, lunch, dinner, and daily Kerala meal routines without waste.</p>
      </div>

      <div class="content-grid content-grid--three">
        <% site.testimonials.forEach((testimonial) => { %>
          <article class="quote-block reveal-on-scroll">
            <p>“<%= testimonial.quote %>”</p>
            <footer>
              <strong><%= testimonial.author %></strong>
              <span><%= testimonial.role %></span>
            </footer>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="section shell">
      <div class="final-cta">
        <div>
          <h2>Subscribe Today</h2>
          <p><%= site.home.subscribeIntro %></p>
          <p class="small-note">Choose a weekly plan or start with a one-time checkout.</p>
        </div>
        <div class="final-cta__actions">
          <a class="button button-primary" href="/subscribe">See weekly plans</a>
          <a class="button button-secondary" href="/shop">Buy a single box</a>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
