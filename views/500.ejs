<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', {
    pageTitle: `Server Error | ${site.name}`,
    pageDescription: 'An unexpected server error occurred.'
  }) %>
</head>
<body class="page">
  <div class="page-frame"></div>
  <%- include('partials/nav') %>

  <main class="page-main">
    <section class="section section--narrow utility-page">
      <p class="eyebrow">500</p>
      <h1 class="page-title">Something went wrong.</h1>
      <p class="lede">Please refresh the page or try again in a moment.</p>
      <div class="hero__actions">
        <a class="button button--primary" href="/">Go home</a>
        <a class="button button--secondary" href="/subscribe">Subscribe later</a>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
