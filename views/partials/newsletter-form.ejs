<form
  class="newsletter-form js-newsletter-form <%= typeof variant !== 'undefined' ? variant : '' %>"
  action="/subscribe"
  method="post"
  novalidate
>
  <input type="hidden" name="source" value="<%= typeof source !== 'undefined' ? source : 'site' %>">

  <div class="newsletter-form__honeypot" aria-hidden="true">
    <label>
      Company
      <input type="text" name="company" tabindex="-1" autocomplete="off">
    </label>
  </div>

  <% if (typeof showFirstName !== 'undefined' && showFirstName) { %>
    <label class="field">
      <span>First name</span>
      <input type="text" name="firstName" placeholder="Dennis" autocomplete="given-name">
    </label>
  <% } %>

  <label class="field field--grow">
    <span>Email</span>
    <input type="email" name="email" placeholder="you@example.com" autocomplete="email" required>
  </label>

  <button class="button button--primary" type="submit"><%= typeof submitLabel !== 'undefined' ? submitLabel : 'Join Free' %></button>

  <% if (typeof showFeedback !== 'undefined' && showFeedback && feedback) { %>
    <p class="form-status form-status--<%= feedback.tone %>" role="status"><%= feedback.message %></p>
  <% } else { %>
    <p class="form-status" role="status" hidden></p>
  <% } %>
</form>
