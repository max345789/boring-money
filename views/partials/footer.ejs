<footer class="site-footer">
  <div class="site-footer__inner shell">
    <div class="site-footer__brand">
      <a class="brandmark brandmark--footer" href="/">
        <span class="brandmark__leaf" aria-hidden="true"></span>
        <span class="brandmark__text">
          <span class="brandmark__name">Sprig</span>
          <span class="brandmark__accent">&amp; Soil</span>
        </span>
      </a>
      <p><%= site.shortDescription %></p>
      <a class="site-footer__email" href="mailto:<%= site.supportEmail %>"><%= site.supportEmail %></a>
    </div>

    <nav class="site-footer__links" aria-label="Footer navigation">
      <% site.footerNav.forEach((item) => { %>
        <a href="<%= item.href %>"><%= item.label %></a>
      <% }) %>
    </nav>

    <div class="site-footer__meta">
      <% site.promiseStrip.forEach((item) => { %>
        <span><%= item %></span>
      <% }) %>
      <span>© <%= new Date().getFullYear() %> <%= site.name %></span>
    </div>
  </div>

  <div class="site-footer__areas shell">
    <span>Service areas:</span>
    <% site.areas.forEach((area, index) => { %>
      <a href="<%= area.href %>"><%= area.label %></a><%= index < site.areas.length - 1 ? ' · ' : '' %>
    <% }) %>
  </div>
</footer>
