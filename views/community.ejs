<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', {
    pageTitle: `Community | ${site.name}`,
    pageDescription: 'BoringMoney community membership for buyers and operators.'
  }) %>
</head>
<body class="page">
  <div class="page-frame"></div>
  <%- include('partials/nav') %>

  <main class="page-main">
    <section class="section section--narrow">
      <p class="eyebrow"><%= site.community.eyebrow %></p>
      <h1 class="page-title"><%= site.community.headline %></h1>
      <p class="lede"><%= site.community.body %></p>
    </section>

    <section class="section community-panel">
      <div class="community-panel__price">
        <span>Annual membership</span>
        <strong><%= site.community.price %></strong>
        <a class="button button--primary" href="/subscribe">Join the waitlist</a>
      </div>

      <ul class="bullet-list bullet-list--large">
        <% site.community.benefits.forEach((benefit) => { %>
          <li><%= benefit %></li>
        <% }) %>
      </ul>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
