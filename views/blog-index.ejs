<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', {
    pageTitle: pageTitle,
    pageDescription: pageDescription,
    canonicalUrl,
    canonicalPath,
    ogImage,
    structuredData
  }) %>
</head>
<body class="page">
  <%- include('partials/nav') %>

  <main class="page-main">
    <section class="page-hero shell">
      <p class="eyebrow">Sprig &amp; Soil blog</p>
      <h1>Local guides, recipes, and delivery updates for Kerala microgreens.</h1>
      <p class="lede">This section targets informational keywords, supports local trust, and gives customers clear reasons to order from a nearby grower instead of a generic produce chain.</p>
    </section>

    <section class="section shell">
      <div class="blog-list">
        <% blogPosts.forEach((post) => { %>
          <article class="content-block reveal-on-scroll">
            <h2><a href="<%= post.path %>"><%= post.title %></a></h2>
            <p><%= post.metaDescription %></p>
            <a class="text-link" href="<%= post.path %>">Read article</a>
          </article>
        <% }) %>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
